{
  "name": "pi-web",
  "version": "0.1.0",
  "private": true,
  "description": "Pi extension: web_search and web_fetch tools for searching the web and reading URL content as clean markdown.",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./dist/index.mjs"
    ]
  },
  "scripts": {
    "clean": "rm -rf .tsbuildinfo node_modules/.cache dist",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:@earendil-works/* --external:typebox --external:@sinclair/* --outfile=dist/index.mjs",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test test/ssrf.test.ts test/extract.test.ts test/search.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "e2e:fetch": "node --import tsx scripts/e2e-fetch.ts",
    "e2e:search": "node --import tsx scripts/e2e-search.ts",
    "verify:bundle": "node --import tsx scripts/verify-bundle.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.0",
    "@earendil-works/pi-coding-agent": ">=0.80.0",
    "@earendil-works/pi-tui": ">=0.80.0",
    "typebox": ">=1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/node": "^22.19.0",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typebox": "^1.1.38",
    "typescript": "5.9.3"
  }
}
